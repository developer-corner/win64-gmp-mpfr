+#if defined(_MSC_VER) && defined(_LONG_LONG_LIMB)
+
+// we DO NOT need this for MS Windows but the common.c in tune needs it...
+#ifndef COUNT_LEADING_ZEROS_NEED_CLZ_TAB
+#define COUNT_LEADING_ZEROS_NEED_CLZ_TAB
+#endif
+
+# undef count_leading_zeros
+# undef count_trailing_zeros
+# undef COUNT_LEADING_ZEROS_0
+
+# define count_leading_zeros(count,x) do { (count) = __builtin_clzll(x); } while (0)
+# define count_trailing_zeros(count,x) do { (count) = __builtin_ctzll(x); } while (0)
+# define COUNT_LEADING_ZEROS_0 64
+
+#endif
+
 #ifdef COUNT_LEADING_ZEROS_NEED_CLZ_TAB
