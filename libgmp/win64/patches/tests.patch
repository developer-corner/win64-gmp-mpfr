 tests_end (void)
 {
+#ifdef _WIN64
+  QueryPerformanceCounter(&end);
+  time_consumed = (double)(end.QuadPart - start.QuadPart) / frequency.QuadPart;
+  {
+    char time_str[64];
+    FILE* f = fopen("__time__consumed", "wt");
+    if (NULL != f)
+    {
+      fprintf(f, "%I64u | ", (unsigned __int64)(end.QuadPart - start.QuadPart));
+      memset(time_str, 0x00, sizeof(time_str));
+      switch (snprintf(time_str, sizeof(time_str), "%.6f", time_consumed))
+      {
+        case 8:
+          fprintf(f, "  %s sec(s)\n", time_str);
+          break;
+        case 9:
+          fprintf(f, " %s sec(s)\n", time_str);
+          break;
+        case 10:
+          fprintf(f, "%s sec(s)\n", time_str);
+          break;
+        default:
+          fprintf(f, "  n/a      sec(s)\n");
+          break;
+      }
+      fclose(f);
+    }
+  }
+#endif
+
   tests_rand_end ();
   tests_memory_end ();
+
+#ifdef _WIN64
+  if (!_CrtCheckMemory())
+  {
+    fprintf(stderr, "_CrtCheckMemory FAILED.\n");
+    _CrtMemDumpAllObjectsSince(&cms);
+    exit(101);
+  }
+#endif
 }
 
